datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Ticket {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String
  priority    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id       String @id @default(uuid())
  name     String
  type     String
  status   String
  location String?
}

model User {
  id    String @id @default(uuid())
  name  String
  email String
  role  String
}

model ITService {
  id          String @id @default(uuid())
  name        String
  description String
  price       String
}
